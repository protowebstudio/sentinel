---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroBravo from "@components/library/marketing/hero/HeroBravo.astro";
import NextStepBravo from "../components/library/marketing/cta/bravo/NextStepBravo.astro";
---

<BaseLayout title="Sentinel">
  <HeroBravo
    showBadge={true}
    badgeText="TFM Presentation • Read-only"
    title="Protoweb Studio — Monitoring MVP (TFM)"
    subtitle="A one-page academic overview: objective, architecture, security boundaries, and delivered components. No live data, no metrics, no proofs."
    primaryCtaText="View Component Library"
    primaryCtaHref="/component-library"
    secondaryCtaText="Jump to Overview"
    secondaryCtaHref="#overview"
    backgroundSrc="/assets/landingfolio/avatars-background.png"
  />
<NextStepBravo />
</BaseLayout>



