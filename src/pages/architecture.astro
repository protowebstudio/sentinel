---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Architecture";
---

<BaseLayout title={title}>
  <main class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900">Architecture</h1>
      <p class="mt-3 text-slate-700">
        Read-only overview page for tests and navigation stability. Content can be expanded later.
      </p>
    </header>

    <section class="space-y-3 text-slate-700">
      <p><strong>Mode:</strong> static site (no control plane).</p>
      <p><strong>Security posture:</strong> mutation verbs blocked; strict headers; no cookies by default.</p>
      <p><strong>Build:</strong> Astro static output.</p>
    </section>
  </main>
</BaseLayout>
