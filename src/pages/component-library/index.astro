---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import { groupByDomainAndCategory } from "../../lib/component-registry";

const grouped = groupByDomainAndCategory();
const domains = Object.keys(grouped).sort();
---

<BaseLayout title="Component Library">
  <Header />
  <main class="min-h-screen bg-white">
    <section class="bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 py-14">
        <p class="text-gray-300 text-sm">Appendix</p>
        <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold text-white">Component Library</h1>
        <p class="mt-4 text-gray-300 max-w-2xl">
          Curated UI variants (alpha/bravo naming) used to compose pages. Static previews only.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 py-14">
      {domains.map((domain) => {
        const categories = Object.keys(grouped[domain]).sort();
        return (
          <div class="mb-14">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="text-2xl font-extrabold text-gray-900 capitalize">{domain}</h2>
              <p class="text-sm text-gray-500">{categories.length} categories</p>
            </div>

            <div class="mt-6 space-y-8">
              {categories.map((category) => {
                const items = grouped[domain][category];
                return (
                  <div>
                    <div class="flex items-center justify-between">
                      <h3 class="text-lg font-bold text-gray-900 capitalize">{category}</h3>
                      <span class="text-xs text-gray-500">{items.length} variant(s)</span>
                    </div>

                    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                      {items.map((item) => (
                        <a
                          href={`/component-library/${item.slug}`}
                          class="group border border-gray-200 rounded-2xl p-5 hover:border-gray-400 transition bg-white"
                        >
                          <div class="flex items-center justify-between">
                            <span class="font-semibold text-gray-900">{item.title}</span>
                            <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-700">
                              {item.variant}
                            </span>
                          </div>
                          <p class="mt-2 text-sm text-gray-600">
                            Preview route: <span class="font-mono text-xs text-gray-500">/{item.slug}</span>
                          </p>
                          <div class="mt-4 text-sm font-bold text-gray-900">
                            Open preview →
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>
  </main>
  <Footer />
</BaseLayout>
