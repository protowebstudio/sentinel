---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import { LIBRARY, getEntry } from "../../lib/component-registry";

export function getStaticPaths() {
  return LIBRARY.map((x) => ({
    params: { slug: x.slug },
  }));
}

const slugParam = Astro.params.slug as string;
const entry = getEntry(slugParam || "");

if (!entry) {
  throw new Error(`Component preview not found for slug: ${slugParam}`);
}

const { title, slug, domain, category, variant, Component } = entry;
---

<BaseLayout title={`Component Library — ${title}`}>
  <Header />
  <main class="min-h-screen bg-white">
    <section class="border-b border-gray-200 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 py-10">
        <a href="/component-library" class="text-sm font-bold text-gray-900 hover:underline">← Back to Library</a>
        <h1 class="mt-4 text-3xl font-extrabold text-gray-900">{title}</h1>
        <div class="mt-3 flex flex-wrap gap-2 text-xs">
          <span class="px-2 py-1 rounded-full bg-white border border-gray-200 text-gray-700">domain: {domain}</span>
          <span class="px-2 py-1 rounded-full bg-white border border-gray-200 text-gray-700">category: {category}</span>
          <span class="px-2 py-1 rounded-full bg-white border border-gray-200 text-gray-700">variant: {variant}</span>
          <span class="px-2 py-1 rounded-full bg-white border border-gray-200 text-gray-700">slug: {slug}</span>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 py-10">
      <div class="border border-gray-200 rounded-2xl overflow-hidden">
        <Component />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

