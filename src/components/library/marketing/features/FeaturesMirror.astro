---
type Card = {
  title: string;
  body: string;
  icon: "chart" | "box" | "chip" | "cloud";
  glow?: boolean;
  extra?: string;
};

const {
  heading = "Take the next step without any hassle & get results fast",
  left = [
    { title: "Predictive Insights", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Eleifend nullam consectetur placerat pellentesque ut massa volutpat at. Diam pretium orci dui sagittis.", icon: "chart" },
    { title: "Filtered Data", body: "Eleifend nullam consectetur placerat pellentesque ut massa volutpat at. Diam pretium orci dui sagittis. Norem ipsum dolor sit amet, consectetur adipiscing elit.", icon: "box" },
  ] as Card[],
  right = [
    { title: "Fastest Speed", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Eleifend nullam consectetur placerat pellentesque ut massa volutpat at. Diam pretium orci dui sagittis.", extra: "Eleifend nullam consectetur placerat pelle tesque ut massa volutpat bonur los.", icon: "chip", glow: true },
    { title: "Everything in Cloud", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Eleifend nullam consectetur placerat pellentesque ut massa volutpat at. Diam pretium orci dui sagittis.", icon: "cloud" },
  ] as Card[],
} = Astro.props;

function IconSvg({ icon }: { icon: Card["icon"] }) {
  if (icon === "chart") return `<svg class="w-12 h-12 mx-auto text-gray-400 sm:mx-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`;
  if (icon === "box") return `<svg class="w-12 h-12 mx-auto text-gray-400 sm:mx-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`;
  if (icon === "chip") return `<svg class="w-12 h-12 mx-auto text-gray-400 sm:mx-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>`;
  return `<svg class="w-12 h-12 mx-auto text-gray-400 sm:mx-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>`;
}
---

<section class="py-12 bg-gray-50 sm:py-16 lg:py-20">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="max-w-xl mx-auto text-center xl:max-w-2xl">
      <h2 class="text-3xl font-bold leading-tight text-gray-900 sm:text-4xl xl:text-5xl">{heading}</h2>
    </div>

    <div class="grid max-w-4xl grid-cols-1 mx-auto mt-8 text-center gap-y-4 sm:gap-x-8 sm:grid-cols-2 sm:mt-12 lg:mt-20 sm:text-left">
      <div class="space-y-4 sm:space-y-8">
        {left.map((c) => (
          <div class="overflow-hidden bg-white shadow-md rounded-xl">
            <div class="p-9">
              <Fragment set:html={IconSvg({ icon: c.icon })} />
              <h3 class="mt-8 text-2xl font-bold text-gray-900 sm:mt-20">{c.title}</h3>
              <p class="mt-6 text-base text-gray-600">{c.body}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="space-y-4 sm:space-y-8">
        {right.map((c) => (
          c.glow ? (
            <div class="relative">
              <div class="absolute -inset-1">
                <div class="w-full h-full rotate-180 opacity-30 blur-lg filter" style="background: linear-gradient(90deg, #44ff9a -0.55%, #44b0ff 22.86%, #8b44ff 48.36%, #ff6644 73.33%, #ebff70 99.34%)"></div>
              </div>
              <div class="relative overflow-hidden bg-white shadow-md rounded-xl">
                <div class="p-9">
                  <Fragment set:html={IconSvg({ icon: c.icon })} />
                  <h3 class="mt-8 text-2xl font-bold text-gray-900 sm:mt-20">{c.title}</h3>
                  <p class="mt-6 text-base text-gray-600">{c.body}</p>
                  {c.extra && <p class="mt-6 text-base text-gray-600">{c.extra}</p>}
                </div>
              </div>
            </div>
          ) : (
            <div class="overflow-hidden bg-white shadow-md rounded-xl">
              <div class="p-9">
                <Fragment set:html={IconSvg({ icon: c.icon })} />
                <h3 class="mt-8 text-2xl font-bold text-gray-900 sm:mt-20">{c.title}</h3>
                <p class="mt-6 text-base text-gray-600">{c.body}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </div>
</section>
