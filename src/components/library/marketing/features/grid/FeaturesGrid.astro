---
type Item = {
  title: string;
  body: string;
  blob: "blue" | "orange" | "green" | "purple" | "slate" | "yellow" | "rose" | "lime";
  icon: "shield" | "bolt" | "moon";
};

const items: ReadonlyArray<Item> = [
  { title: "Secured Payments", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "blue", icon: "shield" },
  { title: "Fast & Easy to Load", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "orange", icon: "bolt" },
  { title: "Light & Dark Version", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "green", icon: "moon" },
  { title: "Light & Dark Version", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "purple", icon: "moon" },
  { title: "Fast & Easy to Load", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "slate", icon: "bolt" },
  { title: "Secured Payments", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "yellow", icon: "shield" },
  { title: "Light & Dark Version", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "slate", icon: "moon" },
  { title: "Secured Payments", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "rose", icon: "shield" },
  { title: "Fast & Easy to Load", body: "Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.", blob: "lime", icon: "bolt" },
] as const;

const blobClass = (b: Item["blob"]) => {
  switch (b) {
    case "blue": return "text-blue-100";
    case "orange": return "text-orange-100";
    case "green": return "text-green-100";
    case "purple": return "text-purple-100";
    case "slate": return "text-gray-100";
    case "yellow": return "text-yellow-100";
    case "rose": return "text-rose-100";
    case "lime": return "text-lime-100";
  }
};

const iconClass = (b: Item["blob"]) => {
  switch (b) {
    case "blue": return "text-blue-600";
    case "orange": return "text-orange-600";
    case "green": return "text-green-600";
    case "purple": return "text-purple-600";
    case "slate": return "text-gray-600";
    case "yellow": return "text-yellow-500";
    case "rose": return "text-rose-600";
    case "lime": return "text-lime-600";
  }
};

const iconSvg = (name: Item["icon"], cls: string) => {
  if (name === "shield") return `
<svg class="w-9 h-9 ${cls}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" />
</svg>`;
  if (name === "bolt") return `
<svg class="w-9 h-9 ${cls}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
</svg>`;
  return `
<svg class="w-9 h-9 ${cls}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
</svg>`;
};

const blobSvg = (cls: string) => `
<svg class="${cls} w-[78px] h-[78px] sm:w-[84px] sm:h-[84px]" viewBox="0 0 78 78" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <path d="M63.6911 28.8569C68.0911 48.8121 74.6037 61.2674 53.2349 65.9792C31.8661 70.6909 11.6224 61.2632 7.22232 41.308C2.82229 21.3528 3.6607 12.3967 25.0295 7.68503C46.3982 2.97331 59.2911 8.90171 63.6911 28.8569Z" />
</svg>`;
---

<section class="py-12 bg-white sm:py-16 lg:py-24">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8 items-stretch">
      {items.map((it) => (
        <article class="h-full rounded-2xl border border-slate-200 bg-white shadow-sm">
          <div class="h-full p-6 sm:p-8 flex flex-col">
            <div class="relative mx-auto sm:mx-0 w-fit">
              <Fragment set:html={blobSvg(blobClass(it.blob))} />
              <div class="absolute inset-0 flex items-center justify-center">
                <Fragment set:html={iconSvg(it.icon, iconClass(it.blob))} />
              </div>
            </div>

            <h3 class="mt-6 text-lg font-semibold text-slate-900 leading-snug">
              {it.title}
            </h3>

            <p class="mt-3 text-base text-slate-600 leading-7">
              {it.body}
            </p>

            <div class="mt-auto pt-6">
              <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                Feature
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
