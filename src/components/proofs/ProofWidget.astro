---
import type { ProofResult } from "../../lib/proofs/types";
const { proof } = Astro.props as { proof: ProofResult };
---
<article class="card">
  <div class="row">
    <strong>{proof.name}</strong>
    <span class={`badge ${proof.ok ? "ok" : "bad"}`}>{proof.badge} ({proof.status})</span>
  </div>

  <div class="meta">
    <div>Source: <code>{proof.url}</code></div>
    <div>Served: <code>{proof.servedFrom}</code></div>
    <div>Time: <code>{proof.ts}</code></div>
    {proof.staleReason && <div>Stale: <code>{proof.staleReason}</code></div>}
  </div>

  {Object.keys(proof.headers).length > 0 && (
    <pre class="code">
{Object.entries(proof.headers).map(([k,v]) => `${k}: ${v}`).join("\n")}
    </pre>
  )}
</article>
